# Get this from Supabase: Project Settings → Database → Connection string
#
# For Vercel: use "Transaction pooler" (port 6543), NOT "Direct connection" (port 5432).
# Direct hosts (db.PROJECT_REF.supabase.co) are often IPv6-only; Vercel can fail to connect.
#
# Pooler URI looks like:
# postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
#
# Username is literally "postgres.PROJECT_REF" (with a dot), not just "postgres".

DATABASE_URL=postgresql://postgres.sbltgtzecialnwsdvxfa:parkerracheljoshuawilliam@aws-1-us-east-2.pooler.supabase.com:6543/postgres
